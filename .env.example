# Allmoxy (from Settings → Integrations → API Integration)
ALLMOXY_CLIENT_ID=
ALLMOXY_CLIENT_SECRET=
ALLMOXY_AUTH_URL=https://auth.allmoxy.com/oauth2/token
ALLMOXY_API_BASE_URL=https://api.allmoxy.com
ALLMOXY_INSTANCE=dbs
# Contact Access Key from Integrations → Company Contacts (required for API data calls)
ALLMOXY_CONTACT_KEY=
ALLMOXY_CONTACT_ID=
# Smart API firewall
ALLMOXY_CACHE_TTL_SECONDS=300
ALLMOXY_MAX_REQUESTS_PER_MINUTE=10
# Local SQLite sync
LOCAL_DB_PATH=./data/allmoxy.db
ALLMOXY_SYNC_PER_PAGE=50
ALLMOXY_SYNC_PAGE_DELAY_MS=200
ALLMOXY_SYNC_BUFFER_MINUTES=5
ALLMOXY_SYNC_MAX_WINDOW_HOURS=6
ALLMOXY_SYNC_FIRST_LOOKBACK_HOURS=6
ALLMOXY_SYNC_MAX_PAGES_PER_RESOURCE=200
ALLMOXY_ALLOW_FULL_SYNC=0

# DeepSeek (powers the chatbot) — from https://platform.deepseek.com
DEEPSEEK_API_KEY=
# deepseek-chat = V4 Flash non-thinking (best for tool chat)
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional fallback (unused when DeepSeek is configured)
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_MODEL=gemini-3.5-flash-lite

# Company-only gate (shared password for your team)
APP_PASSWORD=change-me
APP_SESSION_SECRET=replace-with-a-long-random-string
